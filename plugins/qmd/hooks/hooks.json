{
  "description": "QMD plugin hooks: guard Glob/Grep/Task on indexed dirs to enforce qmd-first workflow",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/guard-qmd-search.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/guard-qmd-search.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/guard-qmd-search.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
